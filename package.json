{
    "name": "stopcristudio",
    "version": "0.1.0",
    "description": "A React-based visual editor for OpenAPI specifications",
    "type": "module",
    "packageManager": "pnpm@8.15.4",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "lint": "eslint .",
        "type-check": "tsc --noEmit",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:debug": "playwright test --debug"
    },
    "dependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "zustand": "^4.4.0",
        "swagger-parser": "^10.0.3",
        "js-yaml": "^4.1.0",
        "clsx": "^2.0.0",
        "react-icons": "^4.11.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@types/node": "^20.0.0",
        "@types/js-yaml": "^4.0.5",
        "typescript": "^5.3.0",
        "vite": "^5.0.0",
        "@vitejs/plugin-react": "^4.2.0",
        "tailwindcss": "^3.4.0",
        "postcss": "^8.4.0",
        "autoprefixer": "^10.4.0",
        "eslint": "^8.55.0",
        "eslint-config-react-app": "^7.0.1",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "@playwright/test": "^1.40.0"
    }
}